# Thư mục build của dự án C# (không đưa lên Github)
[Bb]in/
[Oo]bj/
[Oo]ut/

# Cấu hình cài đặt riêng của Visual Studio
.vs/
*.user
*.suo

# Cơ sở dữ liệu và file môi trường riêng
*.db
*.sqlite
appsettings.Development.json

# Bỏ qua các ảnh người dùng upload cục bộ (để tránh rác Github)
wwwroot/uploads/*
!wwwroot/uploads/.gitkeep
